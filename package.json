    "generate:same-title-image-gallery": "python tools/generate-same-title-image-gallery.py",
    "generate:near-miss-image-review": "python tools/generate-near-miss-image-review.py",
    "generate:near-miss-image-gallery": "python tools/generate-near-miss-image-gallery.py",

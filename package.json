    "package:media-requests": "python tools/generate-placeholder-exception-review.py && python tools/generate-same-title-image-review.py && python tools/generate-same-title-image-gallery.py && python tools/generate-near-miss-image-review.py && python tools/generate-near-miss-image-gallery.py && python tools/generate-supplier-media-request-pack.py && python tools/generate-supplier-outreach-tracker.py && python tools/generate-supplier-email-drafts.py && python tools/package-supplier-media-requests.py && python tools/generate-supplier-eml-drafts.py"
